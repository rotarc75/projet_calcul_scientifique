\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{lecture}[2026/02/16 Modele de cours]

% Encodage et Polices
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{lmodern}

% Paquets de base
\RequirePackage{xcolor}
\RequirePackage{geometry}
\RequirePackage{amsmath, amssymb, amsthm}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins, breakable, theorems, listings}
\RequirePackage{titlesec}

% Paquets pour le code
\RequirePackage{inconsolata}
\RequirePackage{listings}


% Jolis dessins
\RequirePackage{tikz}
\usetikzlibrary{shapes.geometric, calc}

\renewcommand{\thechapter}{\Roman{chapter}}
\renewcommand{\thesection}{\arabic{section}}


% Couleurs pour le code (Style VS Code Light)
\definecolor{vscblue}{HTML}{0000FF}    % Mots-clés
\definecolor{vscgreen}{HTML}{008000}   % Commentaires
\definecolor{vscstring}{HTML}{A31515}  % Chaînes de caractères
\definecolor{vscgray}{HTML}{808080}    % Numéros de ligne


\definecolor{accentcolor}{HTML}{8A1538}

% Configuration des styles
\tcbset{
    commonstyle/.style={
        enhanced,
        breakable,
        before skip=12pt,
        after skip=12pt,
        left=0pt,
        right=0pt,
        coltitle=accentcolor,
        fonttitle=\bfseries,
        description font=\normalfont\itshape\color{accentcolor},
        frame empty,
        interior empty,
        colback=white,
        separator sign={.\!},
        top=-3pt,
    },
    simpleblock/.style={commonstyle},
    importantblock/.style={
        commonstyle,
        borderline west={1.5pt}{0pt}{accentcolor},
        left=8pt,
    }
}


% Définition des blocs

\newcounter{compteurcours}[section]
\renewcommand{\thecompteurcours}{\thesection.\arabic{compteurcours}}

\newtcbtheorem[use counter=compteurcours]{definition}{Définition}{simpleblock}{def}
\newtcbtheorem[use counter=compteurcours]{remark}{Remarque}{simpleblock}{rem}
\newtcbtheorem[use counter=compteurcours]{exemple}{Exemple}{simpleblock}{ex}
\newtcbtheorem[use counter=compteurcours]{theoreme}{Théorème}{importantblock}{thm}
\newtcbtheorem[use counter=compteurcours]{proposition}{Proposition}{importantblock}{prop}



% Titre du poly
\newcommand{\makelecturetitle}[3]{
    \begin{center}
        {\color{accentcolor}\hrule height 2pt}\vspace{0.5cm}
        {\color{accentcolor}\Large\scshape #1}\par\vspace{0.3cm}
        {\color{accentcolor}\Huge\bfseries #2}\par\vspace{0.5cm}
        {\color{accentcolor}\hrule height 2pt}\vspace{0.8cm}
        {\large\itshape #3}
    \end{center}
    \vspace{1cm}
}


% Titre des chapitres
\titleformat{\chapter}[display]
  {\normalfont\Huge\bfseries\color{accentcolor}} % Format du texte
  {Chapitre \thechapter.} % Le label
  {0pt} % Espace vertical entre le label et le titre
  {}


% Titre des sections
\titleformat{\section}
  {\normalfont\Large\bfseries\color{accentcolor}}
  {\thesection.}
  {0.5em}
  {}


% ==========================================
% Environnement pour les Réponses
% ==========================================

% Bloc réponse
\newtcolorbox{reponse}[1]{
    enhanced,
    empty, % Fond et cadre transparents
    breakable,
    left=8pt, % Léger retrait du texte pour respirer
    title={Question #1},
    coltitle=accentcolor,
    fonttitle=\large\bfseries,
    attach title to upper=\par\vspace{0.8em}, % Place le titre au-dessus du texte avec un saut de ligne
    before skip=2em, % Espacement rigoureux avant le bloc
    after skip=2em   % Espacement rigoureux après le bloc
}

% ==========================================
% 8. Environnement pour le code (Style VSC DARK - Sécable corrigé)
% ==========================================

\definecolor{vscbg}{RGB}{30, 30, 30}
\definecolor{vsctext}{RGB}{212, 212, 212}
\definecolor{vscgreen}{RGB}{106, 153, 85}
\definecolor{vscblue}{RGB}{86, 156, 214}
\definecolor{vscstring}{RGB}{206, 145, 120}
\definecolor{vscgray}{RGB}{133, 133, 133}

\lstdefinestyle{vscodestyle}{
    language=C++,
    backgroundcolor=\color{vscbg},
    commentstyle=\color{vscgreen}\itshape,
    keywordstyle=\color{vscblue}\bfseries,
    numberstyle=\tiny\color{vscgray},
    stringstyle=\color{vscstring},
    % Modification 1 : on place la couleur à la TOUTE FIN du basicstyle
    basicstyle=\ttfamily\footnotesize\color{vsctext},
    breakatwhitespace=false,
    breaklines=true,
    captionpos=b,
    keepspaces=true,
    numbers=left,
    numbersep=12pt,
    showspaces=false,
    showstringspaces=false,
    showtabs=false,
    tabsize=4,
    extendedchars=true,
    literate=
      {é}{{\'e}}1 {è}{{\`e}}1 {ê}{{\^e}}1 {ë}{{\"e}}1
      {à}{{\`a}}1 {â}{{\^a}}1
      {î}{{\^i}}1 {ï}{{\"i}}1
      {ô}{{\^o}}1
      {û}{{\^u}}1 {ù}{{\`u}}1
      {ç}{{\c c}}1
}

\newtcblisting{codeblock}[1][]{
    listing only,
    listing style=vscodestyle,
    title=#1,
    fonttitle=\bfseries\ttfamily\footnotesize,
    coltitle=white,
    enhanced,
    breakable,
    colback=vscbg,
    colupper=vsctext,
    boxrule=0pt,
    frame empty,
    colbacktitle=black!85,
    colframe=black!85,
    arc=3pt,
    titlerule=0pt,
    left=6mm,
    top=2pt,
    bottom=2pt,
}
